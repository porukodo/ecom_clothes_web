# Copy to .env and run: php scripts/generate_encryption_keys.php
# NEVER commit .env — it is listed in .gitignore

# Master switch (V2 branch). Keep false on main / until keys exist.
ENCRYPTION_ENABLED=false

# RSA key pair (PEM). Use \n for line breaks inside quotes.
RSA_PRIVATE_KEY=""
RSA_PUBLIC_KEY=""

# AES data key wrapped with RSA public key (base64). Raw AES key is NOT stored here.
ENCRYPTED_AES_KEY=""

# Optional: database overrides for future use
DB_HOST=127.0.0.1
DB_NAME=ecom_clothes_web
DB_USER=root
DB_PASS=
